
PORT=3000

# CORS: the Vite dev origin allowed to call this API.
FRONTEND_URL=http://localhost:5173

# Which database backend to use: postgres | mongo. Picks the repository adapter
# at boot; only the selected driver's connection (and *_URL below) is required.
DB_DRIVER=postgres

# Postgres connection string. SECRET.
DATABASE_URL=postgresql://user:pass@localhost:5432/token_dashboard

# MongoDB connection string (database name is taken from the URL path). SECRET.
# Use 127.0.0.1 (not localhost) for a local container: Node resolves localhost
# to IPv6 ::1, but the container publishes the port on IPv4 only.
MONGO_URL=mongodb://127.0.0.1:27017/token_dashboard

# Blockchain access for the ERC-20 Transfer event listener.
RPC_URL=http://127.0.0.1:8545
TOKEN_ADDRESS=

# Bonus: wallet-signature auth. SECRET.
JWT_SECRET=

# Message the wallet is asked to sign on login (any non-empty string). Required by
# the auth flow (auth.service.ts / auth.controller.ts).
WALLET_SIGN_NONCE=Please sign the message
