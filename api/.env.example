# Backend (NestJS). Copy to api/.env and fill in.
#
# SERVER-ONLY. Never prefix these with VITE_ or NEXT_PUBLIC_ — they must never
# reach the browser bundle.
#
# NOTE: the backend currently reads raw process.env and does not auto-load .env yet
# (no @nestjs/config / dotenv wired in). Until the event-listener work adds a config
# module, export these in your shell or add dotenv. These entries document the contract.

PORT=3000

# CORS: the Vite dev origin allowed to call this API.
FRONTEND_URL=http://localhost:5173

# Postgres connection string. SECRET.
DATABASE_URL=postgresql://user:pass@localhost:5432/token_dashboard

# Blockchain access for the (future) ERC-20 Transfer event listener.
RPC_URL=http://127.0.0.1:8545
TOKEN_ADDRESS=

# Bonus: wallet-signature auth. SECRET.
JWT_SECRET=
