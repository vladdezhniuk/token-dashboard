# Frontend (Vite + React). Copy to app/.env and fill in.
#
# IMPORTANT: Vite only exposes variables prefixed with VITE_ to browser code.
# (NEXT_PUBLIC_ does nothing here — this is Vite, not Next.js.)
# Everything below is PUBLIC: it is bundled into the client JS. Never put secrets here.

# Base URL of the NestJS backend. The React app calls it directly (no Next.js gateway),
# so this URL must be browser-visible — that is expected, not a leak.
VITE_API_URL=http://localhost:3000

# Address of the already-deployed ERC-20 token. There is no contract to deploy from
# this repo — use the existing Sepolia token address (see the root README). The Token
# panel and transfers stay disabled until this is set to a valid 0x address.
VITE_TOKEN_ADDRESS=

# Chain the wallet must be connected to. 11155111 = Sepolia (the deployed token, primary);
# 31337 = local Hardhat node (optional). Must match the network of VITE_TOKEN_ADDRESS.
VITE_CHAIN_ID=11155111

# Reown (WalletConnect) project id — required by Reown AppKit / wagmi.
# Create a free project at https://cloud.reown.com and paste its Project ID here.
# Public by nature (shipped to the browser). Injected wallets (MetaMask) work without it,
# but WalletConnect / QR-code connections need it.
VITE_REOWN_PROJECT_ID=
